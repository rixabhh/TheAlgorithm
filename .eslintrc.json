{
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "no-undef": "error"
  },
  "overrides": [
    {
      "files": ["functions/**/*.js"],
      "rules": {
        "no-unused-vars": "off"
      }
    }
  ]
}
