{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "the-algorithm",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "ai": {
    "binding": "AI"
  },
  "vars": {
    "LLM_PROVIDER": "openai"
  }
}
